# ============================================================
#  WorkToGo CORE — .env Template
#  Copy this to .env and fill in your values.
# ============================================================

APP_NAME=WorkToGo
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=your_64_char_hex_secret_here
JWT_EXPIRY_HOURS=24
JWT_REFRESH_DAYS=7

# Options: debug | info | warning | error
LOG_LEVEL=error

# Lock to your frontend origin in production (e.g. https://app.yourdomain.com)
CORS_ORIGIN=*

SERVICE_ENGINE_DIR=service-engine
SHOPPING_ENGINE_DIR=shopping-engine
VIDEO_ENGINE_DIR=video-engine

# Max requests per IP per minute
RATE_LIMIT_MAX=60

# Options: log | msg91 | fast2sms | twilio
SMS_PROVIDER=log
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
FAST2SMS_KEY=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
