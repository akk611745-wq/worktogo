# Google OAuth
GOOGLE_CLIENT_ID=12060804963-6t9mfjvb36pjvmeps8cl86aa2tpkisuu.apps.googleusercontent.com

# CORS — set to your exact frontend domain (no trailing slash)
CORS_ORIGIN=https://worktogo.in

# Brain CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://worktogo.in

# Paths (relative to public_html — keep outside webroot)
UPLOAD_PATH=../uploads/
LOG_PATH=../logs/

# Internal keys (generate: openssl rand -hex 32)
