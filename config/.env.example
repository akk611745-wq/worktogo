# WorkToGo — Production Environment Template

APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata

# Security Keys (CHANGE THESE IN PRODUCTION)
ADMIN_KEY=your_admin_key_here
HEART_INTERNAL_KEY=your_internal_key_here
JWT_SECRET=your_jwt_secret_here

# Brain Configuration
BRAIN_API_URL=brain
BRAIN_CLIENT_ID=worktogo_heart
BRAIN_API_KEY=123456789WORKTOGO
BRAIN_CIRCUIT_WINDOW=30
BRAIN_CIRCUIT_THRESHOLD=3

# Body Engines (Local Paths)
ENGINE_SHOPPING_URL=body/shopping-engine
ENGINE_SERVICE_URL=body/service-engine/api/services/index.php
ENGINE_DELIVERY_URL=body/delivery-engine
ENGINE_VIDEO_URL=body/video-engine

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=worktogo_db
DB_USER=worktogo_user
DB_PASS=worktogo_password

# Cache Drivers (Optional)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# Logging
HEART_LOG_LEVEL=WARN
TRUST_PROXY=false
CORS_ORIGIN=*

# External Services
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
SWIFTDELIVER_API_KEY=
