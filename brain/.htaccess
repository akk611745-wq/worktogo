Options -Indexes

RewriteEngine On
RewriteBase /brain/
# Block direct access to sensitive folders
RewriteRule ^(config|database|logs|scripts)/ - [F,L]

# Skip real files and folders
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else to index.php
RewriteRule ^ index.php [QSA,L]

# Block direct access to .env files
<FilesMatch "^\.env">
    Order deny,allow
    Deny from all
</FilesMatch>

# Block access to composer/package files
<FilesMatch "^(composer\.json|composer\.lock|package\.json|package-lock\.json|\.git)">
    Order deny,allow
    Deny from all
</FilesMatch>
