# =====================================================================
# BrainCore v3 — Environment Configuration
# Copy this file to .env and fill in all REPLACE_WITH_ values.
# NEVER commit .env to version control.
# =====================================================================

# ── Application ───────────────────────────────────────────────────────
APP_NAME=BrainCore
APP_ENV=production
APP_VERSION=3.0

# ── Database ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=REPLACE_WITH_YOUR_DB_NAME
DB_USER=REPLACE_WITH_YOUR_DB_USER
DB_PASS=REPLACE_WITH_YOUR_DB_PASSWORD
DB_TIMEZONE=+00:00

# ── Security Keys ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ADMIN_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
CRON_KEY=REPLACE_WITH_LONG_RANDOM_SECRET

# ── CORS ──────────────────────────────────────────────────────────────
# Production: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=warning
LOG_FILE=logs/braincore.log

# ── Admin Notifications ───────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com

# ── Integration Mode ──────────────────────────────────────────────────
# simulation = no external HTTP calls (safe for staging/testing)
# live       = real HTTP calls to integration URLs below
INTEGRATION_MODE=simulation
INTEGRATION_TIMEOUT=5

# ── Integration Endpoints (leave blank if not used) ───────────────────
INTEGRATION_NOTIFY_USER_URL=
INTEGRATION_NOTIFY_VENDOR_URL=
INTEGRATION_POPUP_URL=
INTEGRATION_BOOST_URL=
INTEGRATION_WEBHOOK_URL=

# ── Integration Tokens ────────────────────────────────────────────────
INTEGRATION_NOTIFY_USER_TOKEN=
INTEGRATION_NOTIFY_VENDOR_TOKEN=
INTEGRATION_WEBHOOK_TOKEN=

# ── Data Retention ────────────────────────────────────────────────────
EVENT_RETENTION_DAYS=90
DECISION_RETENTION_DAYS=90
